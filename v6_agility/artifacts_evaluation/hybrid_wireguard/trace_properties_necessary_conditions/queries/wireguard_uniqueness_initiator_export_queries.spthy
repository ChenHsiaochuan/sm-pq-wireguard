#ifdef all_trusted

export queries:

"

set nounifIgnoreNtimes = 4.
noselect x:bitstring; attacker(exp(g,x)).
noselect x:bitstring; attacker(h(x)).
noselect x, y: bitstring; attacker(senc( *x, h( *y)))[ignoreAFewTimes].

query ldhi:bitstring, ldhr:bitstring, dheki:bitstring, dhekr:bitstring, ldhi':bitstring, ldhr':bitstring, dheki':bitstring, dhekr':bitstring, kemltki:bitstring, kemltkr:bitstring, kemltki':bitstring, kemltkr':bitstring, kempeki:bitstring, kempeki':bitstring, psk:bitstring, psk':bitstring, ck:bitstring, rb:bitstring, ra:bitstring, re:bitstring, rb':bitstring, ra':bitstring, re':bitstring;
event(eIConfirm(ck, kemltki, kemltkr, ldhi, ldhr, kempeki, dheki, dhekr, psk, h(rb), h(ra), h(re))) && event(eIConfirm(ck, kemltki, kemltkr, ldhi, ldhr, kempeki', dheki', dhekr', psk, h(rb'), h(ra'), h(re')))
==> ((dheki = dheki') && (dhekr = dhekr') && (kempeki = kempeki') && (rb = rb') && (ra = ra') && (re = re')).

