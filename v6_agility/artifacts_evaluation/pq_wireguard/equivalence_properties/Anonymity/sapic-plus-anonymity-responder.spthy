/*
 * Artifacts for Usenix 2025 paper "A Tale of Two Worlds, a Formal Story of WireGuard Hybridization"
 */

theory PQWireGuard

begin

builtins: hashing, dest-asymmetric-encryption, dest-pairing

functions: kdf1/1, kdf2/1, kdf3/1, aead/4, decrypt/3[destructor], checkaead/4[destructor], mac/2, checkmac/3[destructor], true/0
equations: decrypt(k, n, aead(k, n, a, p)) = p
equations: checkaead(k, n, a, aead(k, n, a, p)) = true
equations: checkmac(k, m, mac(k,m)) = true

// beginning of initiator process

let Initiator(~kemltkI, tpkI, kempkR, psk) =

    let kempkI = pk(~kemltkI) in
    new ~rb;
    new ~kemekI;
    new ~ts;
    new sidI;

    //InitHello generation

    let kempekI = pk(~kemekI) in
    let ck=h('noise') in
    let kb = h(<~rb, tpkI>) in

    (   // This parallelizes kemekI, rb compromise

      let hi0   = h(<ck, 'ident'>) in
      let hi1   = h(<hi0, kempkR>) in
      let ci0   = kdf1(<ck, kempekI>) in

      let ct1 = aenc(kb, kempkR) in

      let hi2   = h(<hi1, kempekI>) in
      let ci1   = kdf1(<ci0, kb>) in
      let ki1   = kdf2(<ci0, kb>) in

      let astat = aead(ki1, 'zerostring', hi2, h(kempkI)) in
      let hi3   = h(<hi2, astat>) in
      let ci2 = kdf1(<ci1, psk>) in
      let ki2 = kdf2(<ci1, psk>) in
      let ats = aead(ki2, 'zerostring', hi3, ~ts) in
      let hi4   = h(<hi3, ats>) in

      let kmacI1 = h(<'noise', kempkR>) in
      let macI1 = mac(kmacI1, <sidI, kempekI, ct1, astat, ats>) in

      event ISend(ki2, kempkI, kempkR, tpkI, kempekI, psk, kb);
      out(<'xI', sidI, kempekI, ct1, astat, ats, macI1>);    // Send InitHello

      // RecHello reception

      let kmacR = h(<'noise', kempkI>) in        // mac key
      in(<'xR', sidIR, sidR, ct2, ct3, aempt, macR>);   // Receive RecHello

      if((checkmac(kmacR, <sidIR, sidR, ct2, ct3, aempt>, macR)=true)) then
      (
          if(sidIR=sidI) then
              (

                  let ke = adec(ct2, ~kemekI) in
                  let ka = adec(ct3, ~kemltkI) in

                  let ci3   = kdf1(<ci2, ct2>) in
                  let hi5   = h(<hi4, ct2>) in
                  let ci4   = kdf1(<ci3, ke>) in
                  let ci5   = kdf1(<ci4, ka>) in
                  let ci6   = kdf1(<ci5, psk>) in
                  let hit   = kdf2(<ci5, psk>) in
                  let ki6   = kdf3(<ci5, psk>) in
                  let hi6   = h(<hi5, hit>) in

                  let dempty = decrypt(ki6, 'zerostring', aempt) in

                  if(checkaead(ki6, 'zerostring', hi6, aempt) = true) then
                      (

                      if(dempty='empty') then
                      (
                      event IKeys(ki6, kempkI, kempkR, tpkI, kempekI, psk, kb, ka, ke);

                      let hi7 = h(<hi6, aempt>) in

                      let ci7 = kdf1(ci6) in
                      let ki7 = kdf2(ci6) in
                      event I_SK7(ki7, kempkI, kempkR, tpkI, kempekI, psk, kb, ka, ke);

                      // confirm message for pq-wg
                      let conf = aead(ki7, 'zerostring', hi7, 'empty') in
                      let macI1Conf = mac(kmacI1, <sidI, sidR, conf>) in

                      event IConfirm(ki7, kempkI, kempkR, tpkI, kempekI, psk, kb, ka, ke);
                      out(<'xTi0', sidI, sidR, conf, macI1Conf>)    // Send Confirm
                      )
                      ) // chekaead & dempty = 'empty'
             ) // sidIR = sidI
      )   // checkmac
    )

// end of initiator process

let Responder(~kemltkR, tpkR, kempkI, psk) =

    let kempkR = pk(~kemltkR) in
    new ~re;
    new ~ra;
    new sidR;
    let ka = h(<~ra, tpkR>) in
    let ke = h(~re) in

    let ct3 = aenc(ka, kempkI) in

    ( // This parallelizes ra, re compromise

    // InitHello reception
    let ck = h('noise') in

    let kmacI1 = h(<'noise', kempkR>) in        // mac key
    in(<'xI', sidI, kempekI, ct1, astat, ats, macI1>);

    if(checkmac(kmacI1, <sidI, kempekI, ct1, astat, ats>, macI1) = true) then
    (
        let hr0 = h(<ck, 'ident'>) in
        let hr1 = h(<hr0, kempkR>) in
        let cr0   = kdf1(<ck, kempekI>) in
        let hr2   = h(<hr1, kempekI>) in

        let kb = adec(ct1, ~kemltkR) in

        let cr1   = kdf1(<cr0, kb>) in
        let kr1   = kdf2(<cr0, kb>) in

        let hpkikem = decrypt(kr1, 'zerostring', astat) in
        if(checkaead(kr1, 'zerostring', hr2, astat) = true) then
            (
            if(hpkikem=h(kempkI)) then
            (
            let hr3   = h(<hr2, astat>) in
            let cr2   = kdf1(<cr1, psk>) in //
            let kr2   = kdf2(<cr1, psk>) in //

            let dtime = decrypt(kr2, 'zerostring', ats) in

            if(checkaead(kr2, 'zerostring', hr3, ats) = true) then
                (
                let hr4 = h(<hr3, ats>) in
                event RRec(kr2, kempkI, kempkR, tpkR, kempekI, psk, kb, ka, ke);

                // Rechello generation

                let ct2 = aenc(ke, kempekI) in

                let cr3 = kdf1(<cr2, ct2>) in
                let hr5 = h(<hr4, ct2>) in
                let cr4 = kdf1(<cr3, ke>) in
                let cr5 = kdf1(<cr4, ka>) in
                let cr6 = kdf1(<cr5, psk>) in
                let hrt = kdf2(<cr5, psk>) in
                let kr6 = kdf3(<cr5, psk>) in
                let hr6 = h(<hr5, hrt>) in

                let aempt = aead(kr6, 'zerostring', hr6, 'empty') in
                let hr7 = h(<hr6, aempt>) in

                let kmacR = h(<'noise', kempkI>) in        // mac key
                let macR = mac(kmacR, <sidI, sidR, ct2, ct3, aempt>) in

                event RKeys(kr6, kempkI, kempkR, tpkR, kempekI, psk, kb, ka, ke);
                out(<'xR', sidI, sidR, ct2, ct3, aempt, macR>);  // Send RecHello

                // receive conf message

                let cr7 = kdf1(cr6) in
                let kr7 = kdf2(cr6) in
                event R_SK7(kr7, kempkI, kempkR, tpkR, kempekI, psk, kb, ka, ke);

                in(<'xTi0', sidIC, sidRC, conf, macConf>);

                let dempty = decrypt(kr7, 'zerostring', conf) in

                if (checkmac(kmacI1, <sidIC, sidRC, conf>, macConf)=true) then
                if (dempty='empty') then
                (
                if (sidIC = sidI) then
                if (sidRC = sidR) then
                    (
                        event RConfirm(kr7, kempkI, kempkR, tpkR, kempekI, psk, kb, ka, ke)
                    )
                )   // checkmac
                )   // checkaead
              )     // hpkikem=h(kempkI)
              )    // checkaead

        )   // checkmac1

    )

// end of responder process

export queries:
"
set simplifyProcess = false.
set reconstructTrace = false.
"

process:
0

diffEquivLemma:
(
!(
new ~kemltkR1;
new ~kemltkR2;
new ~tpkI;
new ~tpkR;
new ~kemltkI;
new ~psk;
out(<pk(~kemltkR1), pk(~kemltkR2), pk(~kemltkI)>);
let kemltkR = diff(~kemltkR1, ~kemltkR2) in
(
  (! Initiator(~kemltkI, ~tpkI, pk(kemltkR), ~psk))
| (! Responder(kemltkR, ~tpkR, pk(~kemltkI), ~psk))
)

)
)


export requests:
"
free kemltkR1, kemltkR2, kemltkI, psk, tpkI, tpkR [private].

let sys1 = out(att, (pk(kemltkR1), pk(kemltkR2), pk(kemltkI)));  (!^1 Initiator(kemltkI, tpkI, pk(kemltkR1), psk) | !^1 Responder(kemltkR1, tpkR, pk(kemltkI), psk)).

let sys2 = out(att, (pk(kemltkR1), pk(kemltkR2), pk(kemltkI)));  (!^1 Initiator(kemltkI, tpkI, pk(kemltkR2), psk) | !^1 Responder(kemltkR2, tpkR, pk(kemltkI), psk)).
query trace_equiv(sys1,sys2).


"
// end of process
end
