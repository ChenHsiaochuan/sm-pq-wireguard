let Responder(kemltkR_2:bitstring, kempkI_2:bitstring, psk_2:bitstring)=
    let kempkR_2:bitstring=pk(kemltkR_2) in
    new re_2:bitstring;
    new ra_2:bitstring;
    new sidR_2:bitstring;
    let ka_2:bitstring=h(ra_2) in
    let ke_2:bitstring=h(re_2) in
