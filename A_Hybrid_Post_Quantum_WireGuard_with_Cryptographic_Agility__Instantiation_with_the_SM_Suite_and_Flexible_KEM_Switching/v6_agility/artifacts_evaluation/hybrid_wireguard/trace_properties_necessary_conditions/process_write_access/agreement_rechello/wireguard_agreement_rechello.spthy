/*
 * Artifacts for Usenix 2025 paper "A Tale of Two Worlds, a Formal Story of WireGuard Hybridization"
 */

theory HybridWireGuard

begin

builtins: hashing, diffie-hellman, asymmetric-encryption, symmetric-encryption

functions: kdf1/1, kdf2/1, kdf3/1, aead/4, xaead/4, decrypt/3[destructor], xdecrypt/3[destructor], checkaead/4[destructor], checkxaead/4[destructor], mac/2, checkmac/3[destructor], true/0
equations: decrypt(k, n, aead(k, n, a, p)) = p
equations: checkaead(k, n, a, aead(k, n, a, p)) = true
equations: xdecrypt(k, n, xaead(k, n, a, p)) = p
equations: checkxaead(k, n, a, xaead(k, n, a, p)) = true
equations: checkmac(k, m, mac(k,m)) = true


heuristic: s

let RevealLDH(ldh) =
    event RevLDH('g'^ldh); out(ldh)

let RevealPRE(ldha, ldhb)=
    event RevPre('g'^ldha, 'g'^ldhb); out(('g'^ldha)^ldhb)

let RevealDHE(dhe) =
    event RevDHE('g'^dhe); out(dhe)

let RevealKEMLtk(kemltkr) =
    event RevKEMLtk(pk(kemltkr)); out(kemltkr)

let RevealKEMEki(kemeki) =
    event RevKEMEki(pk(kemeki)); out(kemeki)

let RevealRe(re) =
    event RevRe(re); out(re)

let RevealRa(ra) =
    event RevRa(ra); out(ra)

let RevealRb(rb) =
    event RevRb(rb); out(rb)

let RevealPsk(psk) =
    event RevPsk(psk); out(psk)
/*
 * Artifacts for Usenix 2025 paper "A Tale of Two Worlds, a Formal Story of WireGuard Hybridization"
 */

// beginning of initiator process

let Initiator(~kemltkI, ~ldhI, kempkR, dhpkR, psk) =

    let dhpkI = 'g'^(~ldhI) in
    let kempkI = pk(~kemltkI) in

    in(~dhekI);
    in(~rb);
    in(~kemekI);
    new ~ts;
    new sidI;

    new ~firstI;

    let sisr = (dhpkR)^~ldhI in 

    let kempekI = pk(~kemekI) in

    //InitHello generation

    (   // This parallelizes kemekI, dhekI, rb compromise

      let kb = h(~rb) in

      let dhpekI = 'g'^(~dhekI) in

      let ck=h('noise') in

      let eisr  = dhpkR^~dhekI in
      
      let hi0   = h(<ck, 'ident'>) in
      let hi1   = h(<hi0, <dhpkR, kempkR>>) in
      let ci0   = kdf1(<ck, <dhpekI, kempekI>>) in


      // CCA KEM encaps
      let ct1 = aenc(kb, kempkR) in 
      
      let hi2   = h(<hi1, <dhpekI, kempekI>>) in
      let ci1   = kdf1(<ci0, <eisr, kb>>) in
      let ki1   = kdf2(<ci0, <eisr, kb>>) in

      let astat = aead(ki1, 'zerostring', hi2, h(<kempkI, dhpkI>)) in

      let hi3   = h(<hi2, astat>) in
      let ci2 = kdf1(<ci1, <sisr, h(<kempkI, kempkR>)>>) in
      let ki2 = kdf2(<ci1, <sisr, h(<kempkI, kempkR>)>>) in
      let ats = aead(ki2, 'zerostring', hi3, ~ts) in
      let hi4   = h(<hi3, ats>) in

      let kmacI1 = h(<'noise', kempkR, psk>) in
      let macI1 = mac(kmacI1, <sidI, dhpekI, kempekI, ct1, astat, ats>) in

      event ISend(ki2, kempkI, kempkR, dhpkI, dhpkR, kempekI, dhpekI, psk, kb);
      out(<'xI', sidI, dhpekI, kempekI, ct1, astat, ats, macI1>);    // Send InitHello

      // RecHello reception

      let kmacR = h(<'noise', kempkI, psk>) in        // mac key
      in(<'xR', sidIR, sidR, dhpekR, ct2, ct3, aempt, macR>);   // Receive RecHello

      if (not (dhpekR = 'g')) then
      (

      if(sidIR=sidI) then
      (

      if(checkmac(kmacR, <sidIR, sidR, dhpekR, ct2, ct3, aempt>, macR)=true) then
        (

                let eier  = dhpekR^~dhekI in
                let sier  = dhpekR^~ldhI in

                // CPA KEM decaps                
                let ke = adec(ct2, ~kemekI) in

                // CCA KEM decaps
                let ka = adec(ct3, ~kemltkI) in

                let ci3   = kdf1(<ci2, <dhpekR, ct2>>) in
                let hi5   = h(<hi4, <dhpekR, ct2>>) in
                let ci4   = kdf1(<ci3, <eier, ke>>) in
                let ci5   = kdf1(<ci4, <sier, ka>>) in
                let ci6   = kdf1(<ci5, psk>) in
                let hit   = kdf2(<ci5, psk>) in
                let ki6   = kdf3(<ci5, psk>) in
                let hi6   = h(<hi5, hit>) in

                let dempty = decrypt(ki6, 'zerostring', aempt) in

                if(checkaead(ki6, 'zerostring', hi6, aempt) = true) then
                    (
                    if(dempty='empty') then
                    (
                    event IKeys(ki6, kempkI, kempkR, dhpkI, dhpkR, kempekI, dhpekI, dhpekR, psk, kb, ka, ke);

                    let hi7 = h(<hi6, aempt>) in

                    let ci7 = kdf1(ci6) in
                    let ki7 = kdf2(ci6) in
                    event I_SK7(ki7, kempkI, kempkR, dhpkI, dhpkR, kempekI, dhpekI, dhpekR, psk, kb, ka, ke);

                    let keyItoR = kdf1(ki7) in
                    event I_SK_ItoR(keyItoR, kempkI, kempkR, kempekI, psk, ~rb);
                    let keyRtoI = kdf2(ki7) in
                    event I_SK_RtoI(keyRtoI, kempkI, kempkR, kempekI, psk, ~rb);

                    // first transport message shall be I->R
                    let confirmI = aead(keyItoR, 'zerostring', 'empty', ~firstI) in
                    event IConfirm(keyItoR, kempkI, kempkR, dhpkI, dhpkR, kempekI, dhpekI, dhpekR, psk, kb, ka, ke);
                    out(<'xTi0', sidR, 'zerostring', confirmI>)//;

                    ) // dempty = 'empty'
                    ) // chekaead 
                  ) // sidIR = sidI
             ) 
      ) // checkmac
    )     // This parallelizes ekI, rb compromise
    //| (RevealDHE(~dhekI))
    //| (RevealKEMEki(~kemekI))
    //| (RevealRb(~rb))

// end of initiator process
/*
 * Artifacts for Usenix 2025 paper "A Tale of Two Worlds, a Formal Story of WireGuard Hybridization"
 */

// beginning of responder process

let Responder(~kemltkR, ~ldhR, kempkI, dhpkI, psk) =

    let dhpkR = 'g'^(~ldhR) in
    let kempkR = pk(~kemltkR) in

    in(~re);
    in(~ra);
    new sidR;
    in(~dhekR);

    let dhpekR = 'g'^(~dhekR) in

    let ka = h(~ra) in
    let ke = h(~re) in

    // CCA KEM encaps

    let srsi = dhpkI^~ldhR in // precompr input

    ( // This parallelizes ra, re compromise

    // InitHello reception
    let ck = h('noise') in

    in(<'xI', sidI, dhpekI, kempekI, ct1, astat, ats, macI1>);     // Receive InitHello
    //in(<'xI', sidI, dhpekI, kempekI, ct1, astat, ats>);     // Receive InitHello

        let eisr  = dhpekI^~ldhR in

        let hr0 = h(<ck, 'ident'>) in
        let hr1 = h(<hr0, <dhpkR, kempkR>>) in
        let cr0   = kdf1(<ck, <dhpekI, kempekI>>) in
        let hr2   = h(<hr1, <dhpekI, kempekI>>) in

        // CCA KEM decaps
        let kb = adec(ct1, ~kemltkR) in


        let cr1   = kdf1(<cr0, <eisr, kb>>) in
        let kr1   = kdf2(<cr0, <eisr, kb>>) in

        //event R_SK1(kr1, kempkI, kempkR, kempekI, psk, ~tpkR, ka, k, kb, ~ra, ~re);

        let hpkikem = decrypt(kr1, 'zerostring', astat) in

        if(not (dhpekI = 'g')) then
        (
        if(checkaead(kr1, 'zerostring', hr2, astat) = true) then
        (
        let kmacI1 = h(<'noise', kempkR, psk>) in        // mac key
        if(checkmac(kmacI1, <sidI, dhpekI, kempekI, ct1, astat, ats>, macI1) = true) then
        (
        if(hpkikem=h(<kempkI, dhpkI>)) then
        (

        let ct3 = aenc(ka, kempkI) in
        let hr3   = h(<hr2, astat>) in
        let cr2   = kdf1(<cr1, <srsi, h(<kempkI, kempkR>)>>) in
        let kr2   = kdf2(<cr1, <srsi, h(<kempkI, kempkR>)>>) in

        let dtime = decrypt(kr2, 'zerostring', ats) in

        if(checkaead(kr2, 'zerostring', hr3, ats) = true) then
        (

            let hr4 = h(<hr3, ats>) in

            event RRec(kr2, kempkI, kempkR, dhpkI, dhpkR, kempekI, dhpekI, dhpekR, psk, kb, ka, ke);


            // Rechello generation

            let eier  = dhpekI^~dhekR in
            let sier  = dhpkI^~dhekR in

            // CPA KEM encaps
            let ct2 = aenc(ke, kempekI) in

            let cr3 = kdf1(<cr2, <dhpekR, ct2>>) in
            let hr5 = h(<hr4, <dhpekR, ct2>>) in
            let cr4 = kdf1(<cr3, <eier, ke>>) in
            let cr5 = kdf1(<cr4, <sier, ka>>) in
            let cr6 = kdf1(<cr5, psk>) in
            let hrt = kdf2(<cr5, psk>) in
            let kr6 = kdf3(<cr5, psk>) in
            let hr6 = h(<hr5, hrt>) in

            //event R_SK6(kr6, pkI, pkR, ~tpkR, pekI, psk, ka, k, kb);

            let aempt = aead(kr6, 'zerostring', hr6, 'empty') in
            let hr7 = h(<hr6, aempt>) in

            let kmacR = h(<'noise', kempkI, psk>) in       // mac key
            let macR = mac(kmacR, <sidI, sidR, dhpekR, ct2, ct3, aempt>) in

            // here

            event RKeys(kr6, kempkI, kempkR, dhpkI, dhpkR, kempekI, dhpekI, dhpekR, psk, kb, ka, ke);
            out(<'xR', sidI, sidR, dhpekR, ct2, ct3, aempt, macR>);  // Send RecHello

            // receive conf message

            let cr7 = kdf1(cr6) in
            let kr7 = kdf2(cr6) in
            
            event R_SK7(kr7, kempkI, kempkR, dhpkI, dhpkR, kempekI, dhpekI, dhpekR, psk, kb, ka, ke);

            let keyItoR = kdf1(kr7) in
            event R_SK_ItoR(keyItoR, kempkI, kempkR, dhpkI, dhpkR, kempekI, dhpekI, dhpekR, kb, ka, ke);
            let keyRtoI = kdf2(kr7) in
            event R_SK_RtoI(keyRtoI, kempkI, kempkR, dhpkI, dhpkR, kempekI, dhpekI, dhpekR, kb, ka, ke);


            // receive first message I->R
            in(<'xTi0', sidC, cI0, confirmI>);


            if (sidC = sidR) then // true

                (
                if(cI0 = 'zerostring') then
                (

                let dfirstI = decrypt(keyItoR, cI0, confirmI) in
                if(checkaead(keyItoR, cI0, 'empty', confirmI) = true) then
                    (
                        event RConfirm(keyItoR, kempkI, kempkR, dhpkI, dhpkR, kempekI, dhpekI, dhpekR, psk, kb, ka, ke)//;
                    )
                )
                )
            )   // checkaead
            )   // dhpeki
            )   // checkmac
          )    // hpki

        )   // checkaead
    
    ) // This parallelizes ra, re compromise
  //| (RevealDHE(~dhekR))
  //| (RevealRa(~ra))
  //| (RevealRe(~re))

// end of responder process

/*
 * Artifacts for Usenix 2025 paper "A Tale of Two Worlds, a Formal Story of WireGuard Hybridization"
 */

// beginning of process

process:

!
(
in(~ldhI); 
in(~ldhR); 
in(~kemltkI); 
in(~kemltkR); 
in(~psk); 

out(<'initiator', pk(~kemltkI), 'g'^~ldhI>);
out(<'responder', pk(~kemltkR), 'g'^~ldhR>);

(
      (! Initiator(~kemltkI, ~ldhI, pk(~kemltkR), 'g'^~ldhR, ~psk))
    | (! Responder(~kemltkR, ~ldhR, pk(~kemltkI), 'g'^~ldhI, ~psk))
//    | (! Initiator(~kemltkR, ~ldhR, pk(~kemltkI), 'g'^~ldhI, ~psk))
//    | (! Responder(~kemltkI, ~ldhI, pk(~kemltkR), 'g'^~ldhR, ~psk))
//    | RevealKEMLtk(~kemltkI)
//    | RevealKEMLtk(~kemltkR)
//    | RevealLDH(~ldhI)
//    | RevealLDH(~ldhR)
//    | RevealPRE(~ldhI, ~ldhR)
//    | RevealPsk(~psk)

)
)

// end of process

/*
 * Artifacts for Usenix 2025 paper "A Tale of Two Worlds, a Formal Story of WireGuard Hybridization"
 */

export queries:
"

set nounifIgnoreNtimes = 4.
noselect x:bitstring; attacker(exp(g,x)).
noselect x:bitstring; attacker(h(x)).
noselect x, y: bitstring; attacker(senc( *x, h( *y)))[ignoreAFewTimes].


query ldhi:bitstring, ldhr:bitstring, dheki:bitstring, dhekr:bitstring, ldhi':bitstring, ldhr':bitstring, dheki':bitstring, dhekr':bitstring, kemltki:bitstring, kemltkr:bitstring, kemltki':bitstring, kemltkr':bitstring, kempeki:bitstring, kempeki':bitstring, psk:bitstring, ck:bitstring, rb:bitstring, ra:bitstring, re:bitstring, kb:bitstring, ka:bitstring, ke:bitstring, kb':bitstring, ka':bitstring, ke':bitstring;
event(eIKeys(ck, kemltki, kemltkr, ldhi, ldhr, kempeki, dheki, dhekr, psk, h(rb), h(ra), h(re))) ==> event(eRKeys(ck, kemltki, kemltkr, ldhi, ldhr, kempeki, dheki, dhekr, psk, h(rb), h(ra), h(re))).

"

/*
 * Artifacts for Usenix 2025 paper "A Tale of Two Worlds, a Formal Story of WireGuard Hybridization"
 */


end

