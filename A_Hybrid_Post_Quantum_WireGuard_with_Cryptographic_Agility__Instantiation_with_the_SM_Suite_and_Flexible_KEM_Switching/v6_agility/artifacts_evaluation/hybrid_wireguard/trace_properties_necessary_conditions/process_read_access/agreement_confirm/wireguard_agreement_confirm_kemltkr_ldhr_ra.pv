const g:bitstring.
free att:channel.
free sempty:bitstring.
free sident:bitstring.
free sinitiator:bitstring.
free snoise:bitstring.
free sresponder:bitstring.
free sxI:bitstring.
free sxR:bitstring.
free sxTi0:bitstring.
free szerostring:bitstring.
