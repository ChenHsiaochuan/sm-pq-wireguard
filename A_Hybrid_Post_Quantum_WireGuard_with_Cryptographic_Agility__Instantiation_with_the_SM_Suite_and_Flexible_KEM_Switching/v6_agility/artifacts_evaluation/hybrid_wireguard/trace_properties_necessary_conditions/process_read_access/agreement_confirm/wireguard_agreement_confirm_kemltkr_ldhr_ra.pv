process
    !
    (new ldhI_2:bitstring;
     new ldhR_2:bitstring;
     new kemltkI_2:bitstring;
     new kemltkR_2:bitstring;
     new psk_2:bitstring;
     out(att,(sinitiator, (pk(kemltkI_2), exp(g, ldhI_2))));
     out(att,(sresponder, (pk(kemltkR_2), exp(g, ldhR_2))));
