#ifdef all_trusted

export queries:

"

set nounifIgnoreNtimes = 4.
noselect x:bitstring; attacker(exp(g,x)).
noselect x:bitstring; attacker(h(x)).
noselect x, y: bitstring; attacker(senc( *x, h( *y)))[ignoreAFewTimes].

query kemltki:bitstring, kemltkr:bitstring, ldhi:bitstring, ldhr:bitstring, kempeki:bitstring, dheki:bitstring, dhekr:bitstring, psk:bitstring, ck:bitstring, rb:bitstring, ra:bitstring, re:bitstring;
event(eR_SK7(ck, kemltki, kemltkr, ldhi, ldhr, kempeki, dheki, dhekr, psk, h(rb), h(ra), h(re))) && attacker(ck).

query kemltki:bitstring, kemltkr:bitstring, ldhi:bitstring, ldhr:bitstring, kempeki:bitstring, dheki:bitstring, dhekr:bitstring, psk:bitstring, ck:bitstring, rb:bitstring, ra:bitstring, re:bitstring;
event(eR_SK7(ck, kemltki, kemltkr, ldhi, ldhr, kempeki, dheki, dhekr, psk, h(rb), h(ra), h(re))) && attacker(ck)
==> event(eRevKEMLtk(kemltki)).

query kemltki:bitstring, kemltkr:bitstring, ldhi:bitstring, ldhr:bitstring, kempeki:bitstring, dheki:bitstring, dhekr:bitstring, psk:bitstring, ck:bitstring, rb:bitstring, ra:bitstring, re:bitstring;
