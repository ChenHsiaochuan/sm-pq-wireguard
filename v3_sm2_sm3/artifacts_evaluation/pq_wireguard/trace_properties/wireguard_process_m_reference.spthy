// beginning of process

process:

!
(
in(~tpkR);
in(~tpkI);
in(~kemltkI);
in(~kemltkR);
in(~psk);

out(<pk(~kemltkI), pk(~kemltkR)>);

(
      (! Initiator(~kemltkI, ~tpkI, pk(~kemltkR), ~psk))
    | (! Responder(~kemltkR, ~tpkR, pk(~kemltkI), ~psk))
//    | (! Responder(~kemltkI, ~tpkI, pk(~kemltkR), ~psk))
//    | (! Initiator(~kemltkR, ~tpkR, pk(~kemltkI), ~psk))
