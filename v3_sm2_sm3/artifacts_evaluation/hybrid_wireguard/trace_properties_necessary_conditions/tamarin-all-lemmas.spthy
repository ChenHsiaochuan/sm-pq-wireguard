lemma secrecyMul7PFS:
  all-traces
  "∀ #i #l #k ck kempkI kempkR dhpkI dhpkR kempekI dhpekI dhpekR psk
     kb ka ke.
    (((((((((RConfirm( ck, kempkI, kempkR, dhpkI, dhpkR, kempekI,
                       dhpekI, dhpekR, psk, kb, ka, ke
             ) @ #l) ∧
            (IConfirm( ck, kempkI, kempkR, dhpkI, dhpkR, kempekI, dhpekI,
                       dhpekR, psk, kb, ka, ke
             ) @ #k)) ∧
           (K( ck ) @ #i)) ∧
          (¬(∃ #j. ((RevPsk( psk ) @ #j) ∧ (#j < #k)) ∧ (#j < #l)))) ∧
         (¬(∃ #j. ((RevLDH( dhpkR ) @ #j) ∧ (#j < #k)) ∧ (#j < #l)))) ∧
        (¬(∃ #j.
            ((RevPre( dhpkI, dhpkR ) @ #j) ∧ (#j < #k)) ∧ (#j < #l)))) ∧
       (¬(∃ #j. ((RevLDH( dhpkI ) @ #j) ∧ (#j < #k)) ∧ (#j < #l)))) ∧
      (¬(∃ #j. ((RevKEMLtk( kempkR ) @ #j) ∧ (#j < #k)) ∧ (#j < #l)))) ∧
     (¬(∃ #j. ((RevKEMLtk( kempkI ) @ #j) ∧ (#j < #k)) ∧ (#j < #l)))) ⇒
    ((((((((∃ #j1. (RevPsk( psk ) @ #j1) ∧ (#j1 < #i)) ∧
           ((∃ #j2. (RevLDH( dhpkI ) @ #j2) ∧ (#j2 < #i)) ∨
            (∃ #j3. (RevDHE( dhpekR ) @ #j3) ∧ (#j3 < #i)))) ∧
          ((∃ #j2. (RevLDH( dhpkR ) @ #j2) ∧ (#j2 < #i)) ∨
           (∃ #j3. (RevDHE( dhpekI ) @ #j3) ∧ (#j3 < #i)))) ∧
         ((∃ #j3. (RevDHE( dhpekR ) @ #j3) ∧ (#j3 < #i)) ∨
          (∃ #j3. (RevDHE( dhpekI ) @ #j3) ∧ (#j3 < #i)))) ∧
        (((∃ #j1. (RevPre( dhpkI, dhpkR ) @ #j1) ∧ (#j1 < #i)) ∨
          (∃ #j2. (RevLDH( dhpkR ) @ #j2) ∧ (#j2 < #i))) ∨
         (∃ #j2. (RevLDH( dhpkI ) @ #j2) ∧ (#j2 < #i)))) ∧
       ((∃ #j. (RevKEMLtk( kempkI ) @ #j) ∧ (#j < #i)) ∨
        (∃ ra #j. (RevRa( ra ) @ #j) ∧ (#j < #i)))) ∧
      ((∃ #j. (RevKEMLtk( kempkR ) @ #j) ∧ (#j < #i)) ∨
       (∃ rb #j. (RevRb( rb ) @ #j) ∧ (#j < #i)))) ∧
     ((∃ #j. (RevKEMEki( kempekI ) @ #j) ∧ (#j < #i)) ∨
      (∃ re #j. (RevRe( re ) @ #j) ∧ (#j < #i))))"
/*
guarded formula characterizing all counter-examples:
"∃ #i #l #k ck kempkI kempkR dhpkI dhpkR kempekI dhpekI dhpekR psk
   kb ka ke.
  (RConfirm( ck, kempkI, kempkR, dhpkI, dhpkR, kempekI, dhpekI,
             dhpekR, psk, kb, ka, ke
   ) @ #l) ∧
  (IConfirm( ck, kempkI, kempkR, dhpkI, dhpkR, kempekI, dhpekI,
             dhpekR, psk, kb, ka, ke
   ) @ #k) ∧
  (K( ck ) @ #i)
 ∧
  (∀ #j. (RevPsk( psk ) @ #j) ⇒ ((¬(#j < #k)) ∨ (¬(#j < #l)))) ∧
  (∀ #j. (RevLDH( dhpkR ) @ #j) ⇒ ((¬(#j < #k)) ∨ (¬(#j < #l)))) ∧
  (∀ #j.
    (RevPre( dhpkI, dhpkR ) @ #j) ⇒ ((¬(#j < #k)) ∨ (¬(#j < #l)))) ∧
  (∀ #j. (RevLDH( dhpkI ) @ #j) ⇒ ((¬(#j < #k)) ∨ (¬(#j < #l)))) ∧
  (∀ #j.
    (RevKEMLtk( kempkR ) @ #j) ⇒ ((¬(#j < #k)) ∨ (¬(#j < #l)))) ∧
  (∀ #j.
    (RevKEMLtk( kempkI ) @ #j) ⇒ ((¬(#j < #k)) ∨ (¬(#j < #l)))) ∧
  (((∀ #j1. (RevPsk( psk ) @ #j1) ⇒ ¬(#j1 < #i)) ∨
    ((∀ #j2. (RevLDH( dhpkI ) @ #j2) ⇒ ¬(#j2 < #i)) ∧
     (∀ #j3. (RevDHE( dhpekR ) @ #j3) ⇒ ¬(#j3 < #i))) ∨
    ((∀ #j2. (RevLDH( dhpkR ) @ #j2) ⇒ ¬(#j2 < #i)) ∧
     (∀ #j3. (RevDHE( dhpekI ) @ #j3) ⇒ ¬(#j3 < #i))) ∨
    ((∀ #j3. (RevDHE( dhpekR ) @ #j3) ⇒ ¬(#j3 < #i)) ∧
     (∀ #j3. (RevDHE( dhpekI ) @ #j3) ⇒ ¬(#j3 < #i))) ∨
    ((∀ #j1. (RevPre( dhpkI, dhpkR ) @ #j1) ⇒ ¬(#j1 < #i)) ∧
     (∀ #j2. (RevLDH( dhpkR ) @ #j2) ⇒ ¬(#j2 < #i)) ∧
