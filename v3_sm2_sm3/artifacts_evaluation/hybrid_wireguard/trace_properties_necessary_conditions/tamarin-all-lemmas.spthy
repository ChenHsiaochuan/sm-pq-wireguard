lemma secrecyRSK7:
  all-traces
  "∀ #i #k ck kempkI kempkR dhpkI dhpkR kempekI dhpekI dhpekR psk kb
     ka ke.
    ((RConfirm( ck, kempkI, kempkR, dhpkI, dhpkR, kempekI, dhpekI,
                dhpekR, psk, kb, ka, ke
      ) @ #k) ∧
     (K( ck ) @ #i)) ⇒
    ((((∃ #j1. (RevPsk( psk ) @ #j1) ∧ (#j1 < #i)) ∧
       ((∃ #j2. (RevLDH( dhpkI ) @ #j2) ∧ (#j2 < #i)) ∨
        (∃ #j3. (RevDHE( dhpekR ) @ #j3) ∧ (#j3 < #i)))) ∧
      (((∃ #j1. (RevPre( dhpkI, dhpkR ) @ #j1) ∧ (#j1 < #i)) ∨
        (∃ #j2. (RevLDH( dhpkR ) @ #j2) ∧ (#j2 < #i))) ∨
       (∃ #j2. (RevLDH( dhpkI ) @ #j2) ∧ (#j2 < #i)))) ∧
     ((∃ #j. (RevKEMLtk( kempkI ) @ #j) ∧ (#j < #i)) ∨
      (∃ ra #j. (RevRa( ra ) @ #j) ∧ (#j < #i))))"
/*
guarded formula characterizing all counter-examples:
"∃ #i #k ck kempkI kempkR dhpkI dhpkR kempekI dhpekI dhpekR psk kb
   ka ke.
  (RConfirm( ck, kempkI, kempkR, dhpkI, dhpkR, kempekI, dhpekI,
             dhpekR, psk, kb, ka, ke
   ) @ #k) ∧
  (K( ck ) @ #i)
 ∧
  ((∀ #j1. (RevPsk( psk ) @ #j1) ⇒ ¬(#j1 < #i)) ∨
   ((∀ #j2. (RevLDH( dhpkI ) @ #j2) ⇒ ¬(#j2 < #i)) ∧
    (∀ #j3. (RevDHE( dhpekR ) @ #j3) ⇒ ¬(#j3 < #i))) ∨
   ((∀ #j1. (RevPre( dhpkI, dhpkR ) @ #j1) ⇒ ¬(#j1 < #i)) ∧
    (∀ #j2. (RevLDH( dhpkR ) @ #j2) ⇒ ¬(#j2 < #i)) ∧
    (∀ #j2. (RevLDH( dhpkI ) @ #j2) ⇒ ¬(#j2 < #i))) ∨
   ((∀ #j. (RevKEMLtk( kempkI ) @ #j) ⇒ ¬(#j < #i)) ∧
    (∀ ra #j. (RevRa( ra ) @ #j) ⇒ ¬(#j < #i))))"
*/
simplify
solve( (∀ #j1. (RevPsk( ~psk ) @ #j1) ⇒ ¬(#j1 < #i))  ∥
       ((∀ #j2. (RevLDH( 'g'^~ldhI ) @ #j2) ⇒ ¬(#j2 < #i)) ∧
        (∀ #j3. (RevDHE( 'g'^~dhekR ) @ #j3) ⇒ ¬(#j3 < #i)))  ∥
       ((∀ #j1. (RevPre( 'g'^~ldhI, 'g'^~ldhR ) @ #j1) ⇒ ¬(#j1 < #i)) ∧
        (∀ #j2. (RevLDH( 'g'^~ldhR ) @ #j2) ⇒ ¬(#j2 < #i)) ∧
        (∀ #j2. (RevLDH( 'g'^~ldhI ) @ #j2) ⇒ ¬(#j2 < #i)))  ∥
       ((∀ #j. (RevKEMLtk( pk(~kemltkI) ) @ #j) ⇒ ¬(#j < #i)) ∧
        (∀ ra #j. (RevRa( ra ) @ #j) ⇒ ¬(#j < #i))) )
