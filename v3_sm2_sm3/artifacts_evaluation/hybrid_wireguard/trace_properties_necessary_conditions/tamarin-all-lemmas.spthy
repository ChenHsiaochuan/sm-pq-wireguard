theory HybridWireGuard begin

// Function signature and definition of the equational theory E

builtins: diffie-hellman
functions: adec/2, aead/4, aenc/2, checkaead/4, checkmac/3,
           decrypt/3, fst/1, h/1, kdf1/1, kdf2/1, kdf3/1, mac/2, pair/2, pk/1,
           sdec/2, senc/2, snd/1, true/0
equations:
    adec(aenc(x.1, pk(x.2)), x.2) = x.1,
    checkaead(k, n, a, aead(k, n, a, p)) = true,
    checkmac(k, m, mac(k, m)) = true,
    decrypt(k, n, aead(k, n, a, p)) = p,
    fst(<x.1, x.2>) = x.1,
    sdec(senc(x.1, x.2), x.2) = x.1,
    snd(<x.1, x.2>) = x.2



heuristic: s



































lemma agreementInithello:
  all-traces
  "∀ #i ck kempkI kempkR dhpkI dhpkR kempekI dhpekI dhpekR psk kb ka
     ke.
    (RRec( ck, kempkI, kempkR, dhpkI, dhpkR, kempekI, dhpekI, dhpekR,
           psk, kb, ka, ke
     ) @ #i) ⇒
    ((∃ #j.
       (ISend( ck, kempkI, kempkR, dhpkI, dhpkR, kempekI, dhpekI, psk, kb
        ) @ #j) ∧
       (#j < #i)) ∨
     ((∃ #j1. (RevPsk( psk ) @ #j1) ∧ (#j1 < #i)) ∧
      (((∃ #j2. (RevPre( dhpkI, dhpkR ) @ #j2) ∧ (#j2 < #i)) ∨
        (∃ #j4. (RevLDH( dhpkI ) @ #j4) ∧ (#j4 < #i))) ∨
       (∃ #j5. (RevLDH( dhpkR ) @ #j5) ∧ (#j5 < #i)))))"
/*
guarded formula characterizing all counter-examples:
"∃ #i ck kempkI kempkR dhpkI dhpkR kempekI dhpekI dhpekR psk kb ka
   ke.
  (RRec( ck, kempkI, kempkR, dhpkI, dhpkR, kempekI, dhpekI, dhpekR,
         psk, kb, ka, ke
   ) @ #i)
 ∧
  (∀ #j.
    (ISend( ck, kempkI, kempkR, dhpkI, dhpkR, kempekI, dhpekI, psk, kb
     ) @ #j)
   ⇒
    ¬(#j < #i)) ∧
  (((∀ #j1. (RevPsk( psk ) @ #j1) ⇒ ¬(#j1 < #i)) ∨
    ((∀ #j2. (RevPre( dhpkI, dhpkR ) @ #j2) ⇒ ¬(#j2 < #i)) ∧
     (∀ #j4. (RevLDH( dhpkI ) @ #j4) ⇒ ¬(#j4 < #i)) ∧
     (∀ #j5. (RevLDH( dhpkR ) @ #j5) ⇒ ¬(#j5 < #i)))))"
*/
simplify
solve( (∀ #j1. (RevPsk( ~psk ) @ #j1) ⇒ ¬(#j1 < #i))  ∥
       ((∀ #j2. (RevPre( 'g'^~ldhI, 'g'^~ldhR ) @ #j2) ⇒ ¬(#j2 < #i)) ∧
        (∀ #j4. (RevLDH( 'g'^~ldhI ) @ #j4) ⇒ ¬(#j4 < #i)) ∧
        (∀ #j5. (RevLDH( 'g'^~ldhR ) @ #j5) ⇒ ¬(#j5 < #i))) )
  case case_1
  solve( State_1111111111111211111111111111( ~dhekR, ~kemltkI,
                                             ~kemltkR, ~ldhI, ~ldhR, ~psk, ~ra, ~re, astat,
                                             aead(kdf2(<
                                                        kdf1(<kdf1(<h('noise'), dhpekI, kempekI>),
                                                              z, kb>),
                                                        'g'^(~ldhI*~ldhR),
                                                        h(<pk(~kemltkI), pk(~kemltkR)>)>),
                                                  'zerostring',
                                                  h(<
                                                     h(<
                                                        h(<h(<h('noise'), 'ident'>), 'g'^~ldhR,
                                                           pk(~kemltkR)>),
                                                        dhpekI, kempekI>),
                                                     astat>),
                                                  x),
                                             ct1_enc, dhpekI, kempekI, macI1, sidI, sidR
         ) ▶₀ #i )
    case ifdecryptkdfkdfhnoisedhpekIkempekIdhpekIldhRadecsdecctenchdhpekIldhRkemltkRzerostringastathpkkemltkIgldhI_0_111111111111121111111111111
