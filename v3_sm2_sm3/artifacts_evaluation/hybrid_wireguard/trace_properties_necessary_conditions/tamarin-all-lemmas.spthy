                    <sidI, dhpekI, kempekI, ct1_enc,
                     aead(kdf2(<kdf1(<h('noise'), dhpekI, kempekI>), x, x.1>),
                          'zerostring',
                          h(<h(<h(<h('noise'), 'ident'>), 'g'^~ldhR, pk(~kemltkR)>), dhpekI,
                             kempekI>),
                          h(<pk(~kemltkI), 'g'^~ldhI>)),
                     aead(kdf2(<kdf1(<kdf1(<h('noise'), dhpekI, kempekI>), z, kb>),
                                'g'^(~ldhI*~ldhR), h(<pk(~kemltkI), pk(~kemltkR)>)>),
                          'zerostring',
                          h(<
                             h(<h(<h(<h('noise'), 'ident'>), 'g'^~ldhR, pk(~kemltkR)>), dhpekI,
                                kempekI>),
                             aead(kdf2(<kdf1(<h('noise'), dhpekI, kempekI>), x, x.1>),
                                  'zerostring',
                                  h(<h(<h(<h('noise'), 'ident'>), 'g'^~ldhR, pk(~kemltkR)>),
                                     dhpekI, kempekI>),
                                  h(<pk(~kemltkI), 'g'^~ldhI>))
                            >),
                          x.2)
                    >)
           ) @ #vk.14 )
      case c_mac
