    (IConfirm( ck, kempkI, kempkR, dhpkI, dhpkR, kempekI, dhpekI,
               dhpekR, psk, kb, ka, ke
     ) @ #i) ⇒
    (¬(∃ dhpekI2 kb2 kempekI2 #j1.
        (IConfirm( ck, kempkI, kempkR, dhpkI, dhpkR, kempekI2, dhpekI2,
                   dhpekR, psk, kb2, ka, ke
         ) @ #j1) ∧
        (¬(#j1 = #i))))"
