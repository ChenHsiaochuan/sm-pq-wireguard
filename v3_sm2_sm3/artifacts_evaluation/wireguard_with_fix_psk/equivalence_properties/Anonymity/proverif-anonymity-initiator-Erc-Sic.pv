const g:bitstring.
free att:channel.
free sempty:bitstring.
free sident:bitstring.
free snoise:bitstring.
free sxI:bitstring.
free sxR:bitstring.
free sxTi0:bitstring.
free szerostring:bitstring.
fun aead(bitstring,bitstring,bitstring,bitstring):bitstring.
fun checkaead(bitstring,bitstring,bitstring,bitstring):bitstring.
fun decrypt(bitstring,bitstring,bitstring):bitstring.
fun exp(bitstring,bitstring):bitstring.
fun h(bitstring):bitstring.
fun kdf1(bitstring):bitstring.
fun kdf2(bitstring):bitstring.
fun kdf3(bitstring):bitstring.
fun mac(bitstring,bitstring):bitstring.
fun okay():bitstring.
fun pair(bitstring,bitstring):bitstring.
event eIConfirm(bitstring,bitstring,bitstring,bitstring,bitstring,bitstring).
event eIKeys(bitstring,bitstring,bitstring,bitstring,bitstring,bitstring).
event eISend(bitstring,bitstring,bitstring,bitstring,bitstring).
event eRConfirm(bitstring,bitstring,bitstring,bitstring,bitstring,bitstring).
event eRKeys(bitstring,bitstring,bitstring,bitstring,bitstring,bitstring).
event eRRec(bitstring,bitstring,bitstring,bitstring,bitstring,bitstring).
event eRevDHE(bitstring).
event eRevLDH(bitstring).
event eRevPre(bitstring,bitstring).
event eRevPsk(bitstring).
equation forall a:bitstring, k:bitstring, n:bitstring, p:bitstring;   checkaead(k, n, a, aead(k, n, a, p)) = okay.
equation forall a:bitstring, k:bitstring, n:bitstring, p:bitstring;   decrypt(k, n, aead(k, n, a, p)) = p.
equation forall a:bitstring,b:bitstring; exp( exp(g,a),b) = exp(exp(g,b),a).
reduc forall x_1:bitstring, x_2:bitstring;   fst((x_1, x_2)) = x_1.
reduc forall x_1:bitstring, x_2:bitstring;   snd((x_1, x_2)) = x_2.
reduc forall k:bitstring, m:bitstring;   checkmac(k, m, mac(k, m)) = okay.

set simplifyProcess = false.
set reconstructTrace = false.

not x:bitstring; attacker(diff[new ldhR_2,x]).
not x:bitstring; attacker(diff[x,new ldhR_2]).

let RevealLDHR(ldh_2:bitstring)=
    event eRevLDH( exp(g, ldh_2) ).

let RevealDHER(dhe_2:bitstring)=
    event eRevDHE( exp(g, dhe_2) );
    out(att,dhe_2).

not x:bitstring; attacker(diff[new dhekI_2,x]).
not x:bitstring; attacker(diff[x,new dhekI_2]).

let RevealDHEI(dhe_2:bitstring)=
    event eRevDHE( exp(g, dhe_2) ).

let RevealPRE(ldha_2:bitstring, ldhb_2:bitstring)=
    event eRevPre( exp(g, ldha_2), exp(g, ldhb_2) ).

not x:bitstring; attacker(diff[new psk_2,x]).
not x:bitstring; attacker(diff[x,new psk_2]).

let RevealPSK(psk_2:bitstring)=
    event eRevPsk( psk_2 ).

const ch_init_hello,ch_rec_hello:channel [private].

not x:channel; attacker(diff[ch_init_hello,x]).
not x:channel; attacker(diff[x,ch_init_hello]).
not x:channel; attacker(diff[ch_rec_hello,x]).
not x:channel; attacker(diff[x,ch_rec_hello]).

select x,x':bitstring; mess(ch_init_hello, diff[*x,*x']).
select x,x':bitstring; mess(ch_rec_hello,  diff[*x,*x']).

let Initiator_Init_Hello(ldhI_2:bitstring, dhpkR_2:bitstring, psk_2:bitstring)=
    let dhpkI_2:bitstring=exp(g, ldhI_2) in
    new dhekI_2:bitstring;
    new ts_2:bitstring;
    new sidI_2:bitstring;
    new firstI_2:bitstring;
    let sisr_2:bitstring=exp(dhpkR_2, ldhI_2) in
    (

      (let dhpekI_2:bitstring=exp(g, dhekI_2) in
      let ck_2:bitstring=h(snoise) in
      let eisr_2:bitstring=exp(dhpkR_2, dhekI_2) in
      let hi0_2:bitstring=h((ck_2, sident)) in
      let hi1_2:bitstring=h((hi0_2, dhpkR_2)) in
      let ci0_2:bitstring=kdf1((ck_2, dhpekI_2)) in
      let hi2_2:bitstring=h((hi1_2, dhpekI_2)) in
      let ci1_2:bitstring=kdf1((ci0_2, eisr_2)) in
      let ki1_2:bitstring=kdf2((ci0_2, eisr_2)) in
      let astat_2:bitstring=aead(ki1_2, szerostring, hi2_2, dhpkI_2) in
      let hi3_2:bitstring=h((hi2_2, astat_2)) in
      let ci2_2:bitstring=kdf1((ci1_2, sisr_2)) in
      let ki2_2:bitstring=kdf2((ci1_2, sisr_2)) in
      let ats_2:bitstring=aead(ki2_2, szerostring, hi3_2, ts_2) in
      let hi4_2:bitstring=h((hi3_2, ats_2)) in
      let kmacI1_2:bitstring=h((snoise, (dhpkR_2, psk_2))) in
      let macI1_2:bitstring=mac(kmacI1_2,
                                (sidI_2, (dhpekI_2, (astat_2, ats_2)))) in
      event eISend( ki2_2, dhpkI_2, dhpkR_2, dhpekI_2, psk_2 );
      out(att,(sxI, (sidI_2, (dhpekI_2, (astat_2, (ats_2, macI1_2))))));
      out(ch_init_hello, (psk_2, ldhI_2, dhpkR_2, dhpkI_2, hi4_2, sidI_2, dhekI_2, ci2_2, dhpekI_2, firstI_2)))

| RevealDHEI(dhekI_2)).


let Initiator_Confirm =
    ! in(ch_init_hello, (psk_2: bitstring, ldhI_2: bitstring, dhpkR_2: bitstring, dhpkI_2: bitstring, hi4_2: bitstring, sidI_2: bitstring, dhekI_2: bitstring, ci2_2: bitstring, dhpekI_2: bitstring, firstI_2: bitstring));
      let kmacR_2:bitstring=h((snoise, (dhpkI_2, psk_2))) in
      in(att,(=sxR, (sidIR_2:bitstring, (sidR_2:bitstring, (dhpekR_2:bitstring, (aempt_2:bitstring, macR_2:bitstring))))));
      if checkmac(kmacR_2, (sidIR_2, (sidR_2, (dhpekR_2, aempt_2))), macR_2) =
         okay then
          (if dhpekR_2 <> g then
               (if sidIR_2 = sidI_2 then
                    (let eier_2:bitstring=exp(dhpekR_2, dhekI_2) in
                     let sier_2:bitstring=exp(dhpekR_2, ldhI_2) in
                     let ci3_2:bitstring=kdf1((ci2_2, dhpekR_2)) in
                     let hi5_2:bitstring=h((hi4_2, dhpekR_2)) in
                     let ci4_2:bitstring=kdf1((ci3_2, eier_2)) in
                     let ci5_2:bitstring=kdf1((ci4_2, sier_2)) in
                     let ci6_2:bitstring=kdf1((ci5_2, psk_2)) in
                     let hit_2:bitstring=kdf2((ci5_2, psk_2)) in
                     let ki6_2:bitstring=kdf3((ci5_2, psk_2)) in
                     let hi6_2:bitstring=h((hi5_2, hit_2)) in
                     let dempty_2:bitstring=decrypt(ki6_2, szerostring, aempt_2) in
                     if checkaead(ki6_2, szerostring, hi6_2, aempt_2) = okay then
                         (if dempty_2 = sempty then
                              (event eIKeys( ki6_2, dhpkI_2, dhpkR_2, dhpekI_2, dhpekR_2, psk_2 );
                               let hi7_2:bitstring=h((hi6_2, aempt_2)) in
                               let ci7_2:bitstring=kdf1(ci6_2) in
                               let ki7_2:bitstring=kdf2(ci6_2) in
                               let keyItoR_2:bitstring=kdf1(ki7_2) in
                               let keyRtoI_2:bitstring=kdf2(ki7_2) in
                               let confirmI_2:bitstring=aead(keyItoR_2, szerostring, sempty,
                                                             firstI_2) in
                               event eIConfirm( keyItoR_2, dhpkI_2, dhpkR_2, dhpekI_2, dhpekR_2, psk_2
                                     );
                               out(att,(sxTi0, (sidR_2, (szerostring, confirmI_2))))))))).


let Responder_Rec_Hello(ldhR_2:bitstring, dhpkI_2:bitstring, psk_2:bitstring)=
   let dhpkR_2:bitstring=exp(g, ldhR_2) in
   new stamp_2:bitstring;
   new sidR_2:bitstring;
   new dhekR_2:bitstring;
   let ctrI0_2:bitstring=szerostring in
   let dhpekR_2:bitstring=exp(g, dhekR_2) in
   let srsi_2:bitstring=exp(dhpkI_2, ldhR_2) in
   (

    (let ck_2:bitstring=h(snoise) in
     let kmacI1_2:bitstring=h((snoise, (dhpkR_2, psk_2))) in
     in(att,(=sxI, (sidI_2:bitstring, (dhpekI_2:bitstring, (astat_2:bitstring, (ats_2:bitstring, macI1_2:bitstring))))));
     if checkmac(kmacI1_2, (sidI_2, (dhpekI_2, (astat_2, ats_2))), macI1_2) =
        okay then
         (if dhpekI_2 <> g then
              (let eisr_2:bitstring=exp(dhpekI_2, ldhR_2) in
               let hr0_2:bitstring=h((ck_2, sident)) in
               let hr1_2:bitstring=h((hr0_2, dhpkR_2)) in
               let cr0_2:bitstring=kdf1((ck_2, dhpekI_2)) in
               let hr2_2:bitstring=h((hr1_2, dhpekI_2)) in
               let cr1_2:bitstring=kdf1((cr0_2, eisr_2)) in
               let kr1_2:bitstring=kdf2((cr0_2, eisr_2)) in
               let dpki_2:bitstring=decrypt(kr1_2, szerostring, astat_2) in
               if checkaead(kr1_2, szerostring, hr2_2, astat_2) = okay then
                   (if dpki_2 = dhpkI_2 then
                        (let hr3_2:bitstring=h((hr2_2, astat_2)) in
                         let cr2_2:bitstring=kdf1((cr1_2, srsi_2)) in
                         let kr2_2:bitstring=kdf2((cr1_2, srsi_2)) in
                         let dtime_2:bitstring=decrypt(kr2_2, szerostring, ats_2) in
                         if checkaead(kr2_2, szerostring, hr3_2, ats_2) = okay then
                             (let hr4_2:bitstring=h((hr3_2, ats_2)) in
                              event eRRec( kr2_2, dpki_2, dhpkR_2, dhpekI_2, dhpekR_2, psk_2 );
                              let eier_2:bitstring=exp(dhpekI_2, dhekR_2) in
                              let sier_2:bitstring=exp(dhpkI_2, dhekR_2) in
                              let cr3_2:bitstring=kdf1((cr2_2, dhpekR_2)) in
                              let hr5_2:bitstring=h((hr4_2, dhpekR_2)) in
                              let cr4_2:bitstring=kdf1((cr3_2, eier_2)) in
                              let cr5_2:bitstring=kdf1((cr4_2, sier_2)) in
                              let cr6_2:bitstring=kdf1((cr5_2, psk_2)) in
                              let hrt_2:bitstring=kdf2((cr5_2, psk_2)) in
                              let kr6_2:bitstring=kdf3((cr5_2, psk_2)) in
                              let hr6_2:bitstring=h((hr5_2, hrt_2)) in
                              let aempt_2:bitstring=aead(kr6_2, szerostring, hr6_2, sempty) in
                              let hr7_2:bitstring=h((hr6_2, aempt_2)) in
                              let kmacR_2:bitstring=h((snoise, (dhpkI_2, psk_2))) in
                              let macR_2:bitstring=mac(kmacR_2,
                                                       (sidI_2, (sidR_2, (dhpekR_2, aempt_2)))) in
                              event eRKeys( kr6_2, dhpkI_2, dhpkR_2, dhpekI_2, dhpekR_2, psk_2 );
                              out(att,(sxR, (sidI_2, (sidR_2, (dhpekR_2, (aempt_2, macR_2))))));
                              out(ch_rec_hello, (ldhR_2, dhpkI_2, psk_2, dhpkR_2, cr6_2, sidR_2, dhpekR_2, dhpekI_2))
                              ))))))
|  RevealDHER(dhekR_2)).



let Responder_Confirm =
   ! in(ch_rec_hello, (ldhR_2: bitstring, dhpkI_2: bitstring, psk_2: bitstring, dhpkR_2: bitstring, cr6_2: bitstring, sidR_2: bitstring, dhpekR_2: bitstring, dhpekI_2: bitstring));
     let cr7_2:bitstring=kdf1(cr6_2) in
     let kr7_2:bitstring=kdf2(cr6_2) in
     let keyItoR_2:bitstring=kdf1(kr7_2) in
     let keyRtoI_2:bitstring=kdf2(kr7_2) in
     in(att,(=sxTi0, (sidC_2:bitstring, (cI0_2:bitstring, confirmI_2:bitstring))));
     if sidC_2 = sidR_2 then
         (if cI0_2 = szerostring then
              (let dfirstI_2:bitstring=decrypt(keyItoR_2, cI0_2, confirmI_2) in
               if checkaead(keyItoR_2, cI0_2, sempty, confirmI_2) = okay then
                   (event eRConfirm( keyItoR_2, dhpkI_2, dhpkR_2, dhpekI_2,
                                     dhpekR_2, psk_2)))).



process
!
(
 new ldhI1_2:bitstring;out(att, ldhI1_2);
 new ldhI2_2:bitstring;out(att, ldhI2_2);
 new ldhR_2:bitstring;
 new psk_2:bitstring;
 out(att,exp(g, ldhR_2));
 let ldhI_2 = choice[ldhI1_2, ldhI2_2] in
 (
  !Initiator_Init_Hello(ldhI_2, exp(g, ldhR_2), psk_2) | Initiator_Confirm |
  !Responder_Rec_Hello(ldhR_2, exp(g, ldhI_2), psk_2) | Responder_Confirm |
   RevealLDHR(ldhR_2) | RevealPRE(ldhI_2, ldhR_2) | RevealPSK(psk_2)
 )
)



