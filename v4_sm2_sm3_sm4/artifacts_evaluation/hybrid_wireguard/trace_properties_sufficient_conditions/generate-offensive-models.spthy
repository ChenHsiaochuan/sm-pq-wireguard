event(eIKeys( ck, kempkI, kempkR, dhpkI, dhpkR, kempekI, dhpekI, dhpekR, psk, h(rb), h(ra), h(re)));
event(eRKeys( ck, kempkI, kempkR, dhpkI, dhpkR, kempekI, dhpekI, dhpekR, psk, h(rb), h(ra), h(re)));
event(eIKeys( ck, kempkI, kempkR, dhpkI, dhpkR, kempekI, dhpekI, dhpekR, psk, h(rb), h(ra), h(re))) ==>
event(eRKeys( ck, kempkI, kempkR, dhpkI, dhpkR, kempekI, dhpekI, dhpekR, psk, h(rb), h(ra), h(re))).
