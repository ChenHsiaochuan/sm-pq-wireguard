event(eIConfirm( ck, kempkI, kempkR, dhpkI, dhpkR, kempekI, dhpekI, dhpekR, psk, h(rb), h(ra), h(re)));
(event(eRConfirm( ck, kempkI, kempkR, dhpkI, dhpkR, kempekI, dhpekI, dhpekR, psk, h(rb), h(ra), h(re))) &&
event(eIConfirm( ck, kempkI, kempkR, dhpkI, dhpkR, kempekI, dhpekI, dhpekR, psk, h(rb), h(ra), h(re))) &&
attacker(ck)).
"
