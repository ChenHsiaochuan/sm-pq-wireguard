event eIConfirm(bitstring,bitstring,bitstring,bitstring,bitstring,bitstring,bitstring,bitstring,bitstring).
event eIKeys(bitstring,bitstring,bitstring,bitstring,bitstring,bitstring,bitstring,bitstring,bitstring).
event eISend(bitstring,bitstring,bitstring,bitstring,bitstring,bitstring,bitstring).
