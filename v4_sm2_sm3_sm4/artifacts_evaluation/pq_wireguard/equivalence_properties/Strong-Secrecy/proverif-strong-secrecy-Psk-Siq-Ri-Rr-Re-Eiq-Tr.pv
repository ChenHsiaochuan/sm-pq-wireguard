let Initiator(kemltkI_2:bitstring, tpkI_2:bitstring, kempkR_2:bitstring,
              psk_2:bitstring, key: bitstring)=
    let kempkI_2:bitstring=pk(kemltkI_2) in
    new rb_2:bitstring;out(att, rb_2);
    new kemekI_2:bitstring;out(att, kemekI_2);
    new ts_2:bitstring;
    new sidI_2:bitstring;
    let kempekI_2:bitstring=pk(kemekI_2) in
    let ck_2:bitstring=h(snoise) in
    let kb_2:bitstring=h((rb_2, tpkI_2)) in
    let hi0_2:bitstring=h((ck_2, sident)) in
    let hi1_2:bitstring=h((hi0_2, kempkR_2)) in
    let ci0_2:bitstring=kdf1((ck_2, kempekI_2)) in
    let ct1_2:bitstring=aenc(kb_2, kempkR_2) in
    let hi2_2:bitstring=h((hi1_2, kempekI_2)) in
    let ci1_2:bitstring=kdf1((ci0_2, kb_2)) in
    let ki1_2:bitstring=kdf2((ci0_2, kb_2)) in
    let astat_2:bitstring=aead(ki1_2, szerostring, hi2_2, h(kempkI_2)) in
    let hi3_2:bitstring=h((hi2_2, astat_2)) in
    let ci2_2:bitstring=kdf1((ci1_2, psk_2)) in
    let ki2_2:bitstring=kdf2((ci1_2, psk_2)) in
    let ats_2:bitstring=aead(ki2_2, szerostring, hi3_2, ts_2) in
    let hi4_2:bitstring=h((hi3_2, ats_2)) in
    let kmacI1_2:bitstring=h((snoise, kempkR_2)) in
    let macI1_2:bitstring=mac(kmacI1_2,
                              (sidI_2, (kempekI_2, (ct1_2, (astat_2, ats_2))))) in
    event eISend( ki2_2, kempkI_2, kempkR_2, tpkI_2, kempekI_2, psk_2, kb_2
          );
    out(att,(sxI, (sidI_2, (kempekI_2, (ct1_2, (astat_2, (ats_2, macI1_2)))))));
    let kmacR_2:bitstring=h((snoise, kempkI_2)) in
    in(att,(=sxR, (sidIR_2:bitstring, (sidR_2:bitstring, (ct2_2:bitstring, (ct3_2:bitstring, (aempt_2:bitstring, macR_2:bitstring)))))));
    if checkmac(kmacR_2, (sidIR_2, (sidR_2, (ct2_2, (ct3_2, aempt_2)))),
                macR_2) =
       okay then
        (if sidIR_2 = sidI_2 then
             (let ke_2:bitstring=adec(ct2_2, kemekI_2) in
              let ka_2:bitstring=adec(ct3_2, kemltkI_2) in
              let ci3_2:bitstring=kdf1((ci2_2, ct2_2)) in
              let hi5_2:bitstring=h((hi4_2, ct2_2)) in
              let ci4_2:bitstring=kdf1((ci3_2, ke_2)) in
              let ci5_2:bitstring=kdf1((ci4_2, ka_2)) in
              let ci6_2:bitstring=kdf1((ci5_2, psk_2)) in
              let hit_2:bitstring=kdf2((ci5_2, psk_2)) in
              let ki6_2:bitstring=kdf3((ci5_2, psk_2)) in
              let hi6_2:bitstring=h((hi5_2, hit_2)) in
              let dempty_2:bitstring=decrypt(ki6_2, szerostring, aempt_2) in
              if checkaead(ki6_2, szerostring, hi6_2, aempt_2) = okay then
                  (if dempty_2 = sempty then
                       (event eIKeys( ki6_2, kempkI_2, kempkR_2, tpkI_2, kempekI_2, psk_2, kb_2,
                                      ka_2, ke_2
                              );
                        let hi7_2:bitstring=h((hi6_2, aempt_2)) in
                        let ci7_2:bitstring=kdf1(ci6_2) in
                        let ki7_2:bitstring=kdf2(ci6_2) in
                        let alpha = choice[ki7_2, key] in
                        event eI_SK7( ki7_2, kempkI_2, kempkR_2, tpkI_2, kempekI_2, psk_2, kb_2,
                                      ka_2, ke_2
                              );
                        let conf_2:bitstring=aead(alpha, szerostring, hi7_2, sempty) in
                        let macI1Conf_2:bitstring=mac(kmacI1_2, (sidI_2, (sidR_2, conf_2))) in
                        event eIConfirm( ki7_2, kempkI_2, kempkR_2, tpkI_2, kempekI_2, psk_2,
                                         kb_2, ka_2, ke_2
                              );
                        out(att,(sxTi0, (sidI_2, (sidR_2, (conf_2, macI1Conf_2))))))))).

let Responder(kemltkR_2:bitstring, tpkR_2:bitstring, kempkI_2:bitstring,
              psk_2:bitstring, key: bitstring)=
    let kempkR_2:bitstring=pk(kemltkR_2) in
    new re_2:bitstring;out(att, re_2);
    new ra_2:bitstring;out(att, ra_2);
    new sidR_2:bitstring;
    let ka_2:bitstring=h((ra_2, tpkR_2)) in
    let ke_2:bitstring=h(re_2) in
    let ct3_2:bitstring=aenc(ka_2, kempkI_2) in
    let ck_2:bitstring=h(snoise) in
    let kmacI1_2:bitstring=h((snoise, kempkR_2)) in
    in(att,(=sxI, (sidI_2:bitstring, (kempekI_2:bitstring, (ct1_2:bitstring, (astat_2:bitstring, (ats_2:bitstring, macI1_2:bitstring)))))));
    if checkmac(kmacI1_2, (sidI_2, (kempekI_2, (ct1_2, (astat_2, ats_2)))),
                macI1_2) =
       okay then
        (let hr0_2:bitstring=h((ck_2, sident)) in
         let hr1_2:bitstring=h((hr0_2, kempkR_2)) in
         let cr0_2:bitstring=kdf1((ck_2, kempekI_2)) in
         let hr2_2:bitstring=h((hr1_2, kempekI_2)) in
         let kb_2:bitstring=adec(ct1_2, kemltkR_2) in
         let cr1_2:bitstring=kdf1((cr0_2, kb_2)) in
         let kr1_2:bitstring=kdf2((cr0_2, kb_2)) in
         let hpkikem_2:bitstring=decrypt(kr1_2, szerostring, astat_2) in
         if checkaead(kr1_2, szerostring, hr2_2, astat_2) = okay then
             (if hpkikem_2 = h(kempkI_2) then
                  (let hr3_2:bitstring=h((hr2_2, astat_2)) in
                   let cr2_2:bitstring=kdf1((cr1_2, psk_2)) in
                   let kr2_2:bitstring=kdf2((cr1_2, psk_2)) in
                   let dtime_2:bitstring=decrypt(kr2_2, szerostring, ats_2) in
                   if checkaead(kr2_2, szerostring, hr3_2, ats_2) = okay then
                       (let hr4_2:bitstring=h((hr3_2, ats_2)) in
                        event eRRec( kr2_2, kempkI_2, kempkR_2, tpkR_2, kempekI_2, psk_2, kb_2,
                                     ka_2, ke_2
                              );
                        let ct2_2:bitstring=aenc(ke_2, kempekI_2) in
                        let cr3_2:bitstring=kdf1((cr2_2, ct2_2)) in
                        let hr5_2:bitstring=h((hr4_2, ct2_2)) in
                        let cr4_2:bitstring=kdf1((cr3_2, ke_2)) in
                        let cr5_2:bitstring=kdf1((cr4_2, ka_2)) in
                        let cr6_2:bitstring=kdf1((cr5_2, psk_2)) in
                        let hrt_2:bitstring=kdf2((cr5_2, psk_2)) in
                        let kr6_2:bitstring=kdf3((cr5_2, psk_2)) in
                        let hr6_2:bitstring=h((hr5_2, hrt_2)) in
                        let aempt_2:bitstring=aead(kr6_2, szerostring, hr6_2, sempty) in
                        let hr7_2:bitstring=h((hr6_2, aempt_2)) in
                        let kmacR_2:bitstring=h((snoise, kempkI_2)) in
                        let macR_2:bitstring=mac(kmacR_2,
                                                 (sidI_2, (sidR_2, (ct2_2, (ct3_2, aempt_2))))) in
                        event eRKeys( kr6_2, kempkI_2, kempkR_2, tpkR_2, kempekI_2, psk_2, kb_2,
                                      ka_2, ke_2
                              );
                        out(att,(sxR, (sidI_2, (sidR_2, (ct2_2, (ct3_2, (aempt_2, macR_2)))))));
                        let cr7_2:bitstring=kdf1(cr6_2) in
                        let kr7_2:bitstring=kdf2(cr6_2) in
                        let alpha = choice[kr7_2, key] in
                        event eR_SK7( kr7_2, kempkI_2, kempkR_2, tpkR_2, kempekI_2, psk_2, kb_2,
                                      ka_2, ke_2
                              );
                        in(att,(=sxTi0, (sidIC_2:bitstring, (sidRC_2:bitstring, (conf_2:bitstring, macConf_2:bitstring)))));
                        if (sidIC_2 = sidI_2) && (sidRC_2 = sidR_2) then
                        let dempty_2:bitstring=decrypt(alpha, szerostring, conf_2) in
                             event eRConfirm( kr7_2, kempkI_2, kempkR_2, tpkR_2, kempekI_2, psk_2,
                                                        kb_2, ka_2, ke_2))))).


process
  !(
    new tpkR_2:bitstring;out(att, tpkR_2);
    new tpkI_2:bitstring;
    new kemltkI_2:bitstring;out(att, kemltkI_2);
    new kemltkR_2:bitstring;
    new psk_2:bitstring;out(att, psk_2);
