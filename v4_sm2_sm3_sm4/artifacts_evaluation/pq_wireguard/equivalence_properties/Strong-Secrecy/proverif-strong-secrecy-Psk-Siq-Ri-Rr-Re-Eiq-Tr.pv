equation forall a:bitstring, k:bitstring, n:bitstring, p:bitstring;   checkaead(k, n, a, aead(k, n, a, p)) = okay.
equation forall a:bitstring, k:bitstring, n:bitstring, p:bitstring;   decrypt(k, n, aead(k, n, a, p)) = p.
equation forall k:bitstring, m:bitstring;   checkmac(k, m, mac(k, m)) = okay.
equation forall x_1:bitstring, x_2:bitstring;   adec(aenc(x_1, pk(x_2)), x_2) = x_1.
equation forall x_1:bitstring, x_2:bitstring;   fst((x_1, x_2)) = x_1.
equation forall x_1:bitstring, x_2:bitstring;   snd((x_1, x_2)) = x_2.


